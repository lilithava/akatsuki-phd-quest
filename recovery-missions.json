{
  "meta": {
    "name": "Akatsuki Recovery Missions",
    "version": "2.0.0",
    "description": "Low-energy, low-friction missions designed to restore momentum after burnout, overwhelm, or missed days.",
    "lastUpdated": "2026-04-18"
  },

  "recoveryCategories": [
    { "id": "reentry", "name": "Re-Entry", "icon": "🚪", "description": "Returning after absence" },
    { "id": "overwhelm", "name": "Overwhelm Reduction", "icon": "🌊", "description": "When too many tasks" },
    { "id": "burnout", "name": "Burnout Stabilization", "icon": "🔥", "description": "Physical/mental exhaustion" },
    { "id": "clarity", "name": "Clarity Restoration", "icon": "🔍", "description": "When direction is unclear" },
    { "id": "environment", "name": "Environment Reset", "icon": "🧹", "description": "Clearing physical/digital clutter" }
  ],

  "recoveryMissions": [
    {
      "id": "recovery_reentry_2min",
      "title": "2-Minute Re-Entry",
      "category": "reentry",
      "icon": "⏱️",
      "difficulty": "Easy",
      "xp": 10,
      "estimatedTime": 2,
      "energy": "Very Low",
      "priority": "Maintenance",
      
      "triggerConditions": [
        { "type": "missed_days", "count": 1 },
        { "type": "no_completions", "days": 3 }
      ],
      
      "successCriteria": "Any progress made for 2 minutes",
      "failureCondition": "Avoiding the task entirely",
      "reward": "Momentum restored + 10 XP",
      
      "steps": [
        "Open the stalled task or document",
        "Set a 2-minute timer",
        "Work gently without pressure",
        "Stop immediately when timer ends",
        "Celebrate that you started"
      ],
      
      "notes": "This is the smallest possible restart ritual. Even 2 minutes counts as a win."
    },

    {
      "id": "recovery_reentry_open_only",
      "title": "Open the Task Only",
      "category": "reentry",
      "icon": "📂",
      "difficulty": "Very Easy",
      "xp": 5,
      "estimatedTime": 1,
      "energy": "Very Low",
      "priority": "Maintenance",
      
      "triggerConditions": [
        { "type": "missed_days", "count": 3 },
        { "type": "avoidance_pattern", "days": 5 }
      ],
      
      "successCriteria": "File, tab, or document is opened",
      "failureCondition": "Not opening anything",
      "reward": "Activation spark + 5 XP",
      
      "steps": [
        "Find the file or link for the task",
        "Open it",
        "Look at it for 10 seconds",
        "Close or continue — both count as success"
      ],
      
      "notes": "This breaks avoidance loops. Opening is the victory."
    },

    {
      "id": "recovery_overwhelm_3items",
      "title": "List 3 Things Only",
      "category": "overwhelm",
      "icon": "📝",
      "difficulty": "Easy",
      "xp": 10,
      "estimatedTime": 3,
      "energy": "Very Low",
      "priority": "Maintenance",
      
      "triggerConditions": [
        { "type": "active_tasks", "count": 10, "operator": ">" },
        { "type": "overwhelm_reported", "value": true }
      ],
      
      "successCriteria": "Exactly 3 items listed",
      "failureCondition": "Trying to plan everything at once",
      "reward": "Mental clarity restored + 10 XP",
      
      "steps": [
        "Write down 3 things on your mind right now",
        "Circle the easiest one",
        "Do NOT add more items (3 is the limit)",
        "Put the list where you can see it"
      ],
      
      "notes": "Overwhelm shrinks when lists shrink. Trust the 3-item limit."
    },

    {
      "id": "recovery_overwhelm_sort",
      "title": "Sort Into Keep / Drop / Delay",
      "category": "overwhelm",
      "icon": "🗂️",
      "difficulty": "Easy",
      "xp": 15,
      "estimatedTime": 5,
      "energy": "Low",
      "priority": "Maintenance",
      
      "triggerConditions": [
        { "type": "active_tasks", "count": 15, "operator": ">" },
        { "type": "streak_broken", "value": true }
      ],
      
      "successCriteria": "Tasks sorted into 3 buckets",
      "failureCondition": "Keeping everything active",
      "reward": "Reduced cognitive load + 15 XP",
      
      "steps": [
        "List 5-7 tasks from your backlog",
        "Mark each as Keep, Drop, or Delay",
        "Delete or archive the Drop items",
        "Move Delay items to a 'Later' list",
        "Focus only on Keep items for now"
      ],
      
      "notes": "Most tasks can be delayed or dropped. Be ruthless."
    },

    {
      "id": "recovery_burnout_grounding",
      "title": "Grounding Ritual",
      "category": "burnout",
      "icon": "🧘",
      "difficulty": "Easy",
      "xp": 10,
      "estimatedTime": 3,
      "energy": "Very Low",
      "priority": "Critical",
      
      "triggerConditions": [
        { "type": "burnout_detected", "value": true },
        { "type": "streak_broken", "days": 2 }
      ],
      
      "successCriteria": "Complete the grounding steps",
      "failureCondition": "Ignoring physical state and pushing through",
      "reward": "Energy stabilized + 10 XP",
      
      "steps": [
        "Stop what you're doing",
        "Sit or stand still for 10 seconds",
        "Take 5 slow, deep breaths",
        "Relax your shoulders and jaw",
        "Drink a glass of water"
      ],
      
      "notes": "Burnout requires physical reset first. This is non-negotiable."
    },

    {
      "id": "recovery_burnout_microtask",
      "title": "Microtask Restart",
      "category": "burnout",
      "icon": "⚡",
      "difficulty": "Easy",
      "xp": 15,
      "estimatedTime": 3,
      "energy": "Very Low",
      "priority": "Important",
      
      "triggerConditions": [
        { "type": "burnout_detected", "value": true },
        { "type": "fatigue_level", "value": "high" }
      ],
      
      "successCriteria": "One microtask completed",
      "failureCondition": "Trying to do too much at once",
      "reward": "Momentum restored + 15 XP",
      
      "steps": [
        "Pick the smallest possible next step (under 2 minutes)",
        "Do it very slowly, without pressure",
        "Stop immediately after completing",
        "Write down what you did",
        "Rest if needed"
      ],
      
      "notes": "Burnout hates pressure. Microtasks bypass resistance."
    },

    {
      "id": "recovery_clarity_1question",
      "title": "Answer One Clarifying Question",
      "category": "clarity",
      "icon": "❓",
      "difficulty": "Easy",
      "xp": 10,
      "estimatedTime": 2,
      "energy": "Very Low",
      "priority": "Important",
      
      "triggerConditions": [
        { "type": "stuck_on_task", "minutes": 30 },
        { "type": "paralysis_reported", "value": true }
      ],
      
      "successCriteria": "Question answered honestly",
      "failureCondition": "Avoiding the question",
      "reward": "Direction restored + 10 XP",
      
      "steps": [
        "Ask yourself: 'What is the next concrete action?'",
        "Write the answer in one sentence",
        "Do NOT add more questions",
        "Take that action immediately"
      ],
      
      "notes": "Clarity is often one question away."
    },

    {
      "id": "recovery_environment_clear1",
      "title": "Clear One Small Area",
      "category": "environment",
      "icon": "🧹",
      "difficulty": "Very Easy",
      "xp": 10,
      "estimatedTime": 2,
      "energy": "Very Low",
      "priority": "Maintenance",
      
      "triggerConditions": [
        { "type": "environment_clutter", "value": true },
        { "type": "focus_issues", "value": true }
      ],
      
      "successCriteria": "One area cleared",
      "failureCondition": "Trying to clean everything at once",
      "reward": "Reduced friction + 10 XP",
      
      "steps": [
        "Pick one tiny area (desk corner, one folder, browser tabs)",
        "Clear only that area",
        "Stop immediately after",
        "Notice how it feels"
      ],
      
      "notes": "Environment resets reduce cognitive load dramatically."
    },

    {
      "id": "recovery_accountability_check",
      "title": "Accountability Check-In",
      "category": "reentry",
      "icon": "👥",
      "difficulty": "Easy",
      "xp": 15,
      "estimatedTime": 5,
      "energy": "Low",
      "priority": "Important",
      
      "triggerConditions": [
        { "type": "streak_broken", "days": 1 },
        { "type": "isolation_pattern", "days": 3 }
      ],
      
      "successCriteria": "Message sent to accountability partner",
      "failureCondition": "Staying silent and isolated",
      "reward": "Connection restored + 15 XP",
      
      "steps": [
        "Identify one person who supports your work",
        "Write a short message: 'I'm getting back on track today'",
        "Send the message",
        "Ask them for a quick check-in tomorrow"
      ],
      
      "notes": "Accountability breaks shame spirals."
    }
  ],

  "recoveryRules": {
    "autoTrigger": {
      "enabled": true,
      "checkFrequency": "hourly",
      "maxActiveRecoveryMissions": 3
    },
    "xpAdjustment": {
      "baseMultiplier": 0.6,
      "streakBonus": 1.2,
      "notes": "Recovery missions give 60% of normal XP, but 20% bonus if on a streak"
    },
    "cooldown": {
      "sameCategory": 24,
      "sameMission": 72,
      "unit": "hours"
    }
  }
}
