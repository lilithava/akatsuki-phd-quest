  "achievementTracking": {
    "requiredFields": [
      "missions_completed",
      "streak_days",
      "domain_tasks",
      "boss_defeated",
      "level",
      "collection_percentage",
      "category_completion"
    ],
    "progressUpdateEndpoint": "/api/achievements/progress",
    "batchUpdateSize": 10
  },

  "visualFeedback": {
    "onUnlock": {
      "showToast": true,
      "playSound": true,
      "showConfetti": true,
      "duration": 3000
    },
    "onProgress": {
      "showToast": false,
      "updateBadge": true
    }
  }
