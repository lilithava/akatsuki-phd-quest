      "label": "Documentation",
      "icon": "📝",
      "theme": "Eternal Documentation Scrolls",
      "color": "#1abc9c",
      "description": "Logs, evidence capture, version control, and archives"
    },
    {
      "id": "Rituals",
      "label": "Discipline & Rituals",
      "icon": "🌙",
      "theme": "Discipline & Rituals",
      "color": "#f39c12",
      "description": "Startup, shutdown, focus, and reset rituals"
    }
  ],

  "unlockRules": {
    "levels": [
      { "level": 1, "unlocks": ["Mini-Quests", "Rituals"] },
      { "level": 3, "unlocks": ["Standard Missions", "Community Missions"] },
      { "level": 4, "unlocks": ["Documentation Bonuses", "Streak Multipliers"] },
      { "level": 5, "unlocks": ["Hard Missions", "First Boss Battles"] },
      { "level": 7, "unlocks": ["Secret Missions"] },
      { "level": 10, "unlocks": ["Elite Boss Track"] },
      { "level": 12, "unlocks": ["Custom Mission Creation"] },
      { "level": 15, "unlocks": ["Akatsuki Commander Status"] }
    ],
    "bossUnlockConditions": {
      "Literature Hydra": { "level": 5, "prerequisiteMissions": ["complete_lit_matrix"] },
      "Methodology Golem": { "level": 7, "prerequisiteMissions": ["complete_method_design"] },
      "Burnout Demon": { "level": 3, "triggerOn": "streak_break" }
    }
  },

  "winTheDay": {
    "description": "Daily win condition: complete 1 important mission + 1 ritual + 1 documentation action",
    "requirements": {
      "importantMissions": 1,
      "ritualMissions": 1,
      "documentationMissions": 1
    },
    "reward": {
      "xpBonus": 25,
      "coinBonus": 15,
      "streakBonus": 1
    },
    "tags": {
      "importantPriority": ["Critical", "Important"],
      "ritualMissionTypes": ["Ritual"],
      "documentationDomains": ["Documentation"]
    }
  },

  "recoveryRules": {
    "missedDayGrace": 1,
    "backlogTriageTrigger": {
      "missedTasksInDomain": 3,
      "createsMissionType": "Backlog Triage"
    },
    "overwhelmResetTrigger": {
      "brokenStreaksInWeek": 2,
      "createsMissionType": "Overwhelm Reset Protocol"
    },
    "catchUpMode": {
      "enabled": true,
      "description": "Convert heavy missions into smaller recovery missions when behind",
      "conversionRule": "Split Hard/Elite missions into 3-5 smaller Recovery Missions"
    }
  },

  "localStorageKeys": {
    "xp": "ak_xp",
    "level": "ak_level",
    "coins": "ak_coins",
    "streak": "ak_streak",
    "activeTasks": "ak_active_tasks",
    "completedHistory": "ak_history",
    "avatar": "ak_avatar",
    "unlockedAchievements": "ak_achievements",
    "lastResetDate": "ak_last_reset",
    "lastWeeklyReset": "ak_weekly_reset"
  }
}
