{
  "meta": {
    "name": "Akatsuki PhD Quest – Core Rules",
    "version": "1.1.0",
    "description": "Global rules, XP logic, streak logic, mission types, difficulty definitions, unlocks, reset rules, generator logic, and tag enums for the Akatsuki PhD Quest RPG.",
    "author": "Lilith / Akatsuki System",
    "lastUpdated": "2026-04-17"
  },

  "xpRules": {
    "xpPerLevel": 500,
    "maxLevel": 99,
    "coinRatio": 0.20,
    "levelUpBonusCoins": 100,
    "levelUpEffects": {
      "showAnimation": true,
      "animationType": "pulse-glow",
      "playSound": false
    },

    "difficultyXpRanges": {
      "Easy": { "min": 10, "max": 20 },
      "Medium": { "min": 25, "max": 50 },
      "Hard": { "min": 60, "max": 120 },
      "Elite": { "min": 150, "max": 500 }
    },

    "bonuses": {
      "firstCompletion": {
        "xp": 10,
        "description": "First time you complete a mission."
      },
      "streak3Days": {
        "xp": 15,
        "description": "Maintain a 3-day completion streak."
      },
      "streak7Days": {
        "xp": 40,
        "description": "Maintain a 7-day completion streak."
      },
      "bossClear": {
        "xp": 100,
        "description": "Clear a boss battle mission."
      },
      "recoveryMission": {
        "xp": 15,
        "description": "Complete a recovery mission after a miss."
      },
      "perfectDocumentation": {
        "xp": 10,
        "description": "Attach evidence or log to a mission."
      }
    }
  },

  "streakRules": {
    "dayCompletedCondition": {
      "description": "A day counts as completed when at least one repeatable mission is finished.",
      "requiresRepeatableTask": true,
      "allowedRepeatability": ["Daily", "Weekly", "Monthly", "Repeatable"]
    },

    "resetTime": "local-midnight",

    "onReset": {
      "regenerateRepeatableTasks": true,
      "clearStepStateForRepeatables": true,
      "preserveOneTimeCompletion": true
    },

    "streakBreakLogic": {
      "ifYesterdayCompleted": "increment",
      "ifYesterdayNotCompleted": "resetToZero",
      "maxStreakTracked": 365
    },

    "winTheDay": {
      "description": "1 important mission + 1 ritual + 1 documentation action.",
      "requirements": {
        "importantMissions": 1,
        "ritualMissions": 1,
        "documentationMissions": 1
      },
      "tags": {
        "importantPriority": ["Critical", "Important"],
        "ritualMissionTypes": ["Ritual"],
        "documentationDomains": ["Documentation"]
      }
    }
  },

  "missionTypes": [
    {
      "id": "Mini-Quest",
      "description": "Tiny, low-friction missions for momentum and re-entry.",
      "defaultDifficulty": "Easy",
      "isRepeatable": true
    },
    {
      "id": "Standard Mission",
      "description": "Normal work units with clear outcomes.",
      "defaultDifficulty": "Medium",
      "isRepeatable": true
    },
    {
      "id": "Deep Work Mission",
      "description": "Focused blocks for research, writing, or analysis.",
      "defaultDifficulty": "Hard",
      "isRepeatable": true
    },
    {
      "id": "Boss Battle",
      "description": "High-stakes milestones and major deliverables.",
      "defaultDifficulty": "Elite",
      "isRepeatable": false
    },
    {
      "id": "Recovery Mission",
      "description": "Repair, reset, and re-entry missions after failure or backlog.",
      "defaultDifficulty": "Easy",
      "isRepeatable": true
    },
    {
      "id": "Secret Mission",
      "description": "Optional surprise missions surfaced occasionally.",
      "defaultDifficulty": "Medium",
      "isRepeatable": true
    },
    {
      "id": "Ritual",
      "description": "Startup, shutdown, and consistency rituals.",
      "defaultDifficulty": "Easy",
      "isRepeatable": true
    }
  ],

  "difficulties": [
    {
      "id": "Easy",
      "label": "Easy",
      "timeRangeMinutes": { "min": 5, "max": 15 },
      "cognitiveLoad": "Low",
      "defaultXp": 15,
      "examples": [
        "Write daily log",
        "Rename 5 files",
        "Check mission board"
      ]
    },
    {
      "id": "Medium",
      "label": "Medium",
      "timeRangeMinutes": { "min": 20, "max": 60 },
      "cognitiveLoad": "Moderate",
      "defaultXp": 35,
      "examples": [
        "Summarize one article",
        "Build one mastery check",
        "Publish one daily Skool post"
      ]
    },
    {
      "id": "Hard",
      "label": "Hard",
      "timeRangeMinutes": { "min": 60, "max": 180 },
      "cognitiveLoad": "Deep Work",
      "defaultXp": 90,
      "examples": [
        "Draft 500+ words of a chapter",
        "Code one transcript batch",
        "Outline one L2 master class"
      ]
    },
    {
      "id": "Elite",
      "label": "Elite",
      "timeRangeMinutes": { "min": 180, "max": 999 },
      "cognitiveLoad": "High Stakes",
      "defaultXp": 250,
      "examples": [
        "Complete full chapter draft",
        "Run full Skool challenge cycle",
        "Finish thematic analysis across a dataset"
      ]
    }
  ],

  "repeatabilityOptions": [
    "One-time",
    "Repeatable",
    "Daily",
    "Weekly",
    "Monthly",
    "Quarterly"
  ],

  "priorityTags": [
    {
      "id": "Critical",
      "description": "High-impact, time-sensitive, or advisor/PI-facing work."
    },
    {
      "id": "Important",
      "description": "Moves core arcs forward but not on fire."
    },
    {
      "id": "Maintenance",
      "description": "Keeps systems clean, organized, and stable."
    },
    {
      "id": "Optional",
      "description": "Nice-to-have, can be skipped without damage."
    }
  ],

  "energyTags": [
    {
      "id": "Low Energy",
      "description": "Can be done when tired or mentally drained."
    },
    {
      "id": "Standard Focus",
      "description": "Normal working state, moderate focus required."
    },
    {
      "id": "Deep Focus",
      "description": "Requires uninterrupted, high-focus blocks."
    }
  ],

  "contextTags": [
    { "id": "Home", "description": "Home environment tasks." },
    { "id": "Office", "description": "Office or campus office tasks." },
    { "id": "Library", "description": "Library or quiet study space tasks." },
    { "id": "Online", "description": "Browser-based or remote tasks." },
    { "id": "Skool", "description": "Skool platform and community tasks." },
    { "id": "RA", "description": "Research assistantship tasks." },
    { "id": "Writing", "description": "Drafting, revising, or outlining tasks." },
    { "id": "Admin", "description": "Administrative, filing, or logistics tasks." }
  ],

