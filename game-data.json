  "resetRules": {
    "localStorageKeys": {
      "xp": "ak_xp",
      "level": "ak_level",
      "coins": "ak_coins",
      "streak": "ak_streak",
      "sections": "ak_sections",
      "shop": "ak_shop",
      "avatar": "ak_avatar",
      "bank": "ak_bank",
      "undo": "ak_undo",
      "sidebarHidden": "ak_sidebar_hidden",
      "lastResetDate": "ak_last_reset_date",
      "dayCompletedPrefix": "ak_day_completed_",
      "stepsPrefix": "ak_steps_"
    },

    "antiOverwhelmRules": {
      "maxActiveEliteMissions": 3,
      "backlogTriageTrigger": {
        "missedTasksInDomain": 3,
        "createsMissionType": "Backlog Triage"
      },
      "overwhelmResetTrigger": {
        "brokenStreaksInWeek": 2,
        "createsMissionType": "Overwhelm Reset Protocol"
      },
      "catchUpMode": {
        "enabled": true,
        "description": "Convert heavy missions into smaller recovery missions when behind.",
        "conversionRule": "Split Hard/Elite missions into 3–5 smaller Recovery Missions."
      }
    }
  },

  "unlockRules": {
    "levels": [
      { "level": 1, "unlocks": ["Mini-Quests", "Rituals"] },
      { "level": 3, "unlocks": ["Standard Missions", "Community Missions"] },
      { "level": 4, "unlocks": ["Documentation Bonuses", "Streak Multipliers"] },
      { "level": 5, "unlocks": ["Hard Missions", "First Boss Battles"] },
      { "level": 7, "unlocks": ["Secret Missions"] },
      { "level": 10, "unlocks": ["Elite Boss Track"] },
      { "level": 12, "unlocks": ["Custom Mission Creation"] },
      { "level": 15, "unlocks": ["Akatsuki Commander Status"] }
    ]
  },

  "achievementRefs": {
    "file": "achievements.json",
    "ids": [
      "first_blood",
      "scroll_keeper",
      "shadow_scholar",
      "data_hunter",
      "clan_builder",
      "master_architect",
      "signal_interceptor",
      "no_loose_ends",
      "boss_slayer",
      "resurrection_protocol",
      "crimson_streak",
      "akatsuki_commander"
    ]
  },

  "shopRules": {
    "itemsFile": "shop-items.json",
    "maxEquippedPerType": 1,
    "bonusTypes": [
      "xpMultiplier",
      "coinMultiplier",
      "streakProtection",
      "documentationBonus",
      "bossXpBoost"
    ],
    "defaultCosts": {
      "cosmetic": 150,
      "minorBonus": 250,
      "majorBonus": 400
    }
  },

  "avatarRules": {
    "layersFile": "avatar-layers.json",
    "editableName": true,
    "defaultName": "Shadow Scholar",
    "baseStats": {
      "xpMultiplier": 1.0,
      "coinMultiplier": 1.0
    },
    "maxEquippedPerLayer": 1,
    "layers": [
      "skin",
      "hair",
      "outfit",
      "mask",
      "accessory",
      "handItem",
      "companion"
    ]
  },

  "generatorRules": {
    "defaultChainLengths": {
      "today": 2,
      "week": 3,
      "month": 4
    },
    "defaultMissionTypeByDomain": {
      "PhD": "Deep Work Mission",
      "Skool": "Standard Mission",
      "Curriculum": "Standard Mission",
      "Research Assistantship": "Deep Work Mission",
      "Documentation": "Ritual",
      "Rituals": "Ritual",
      "Boss": "Boss Battle",
      "Recovery": "Recovery Mission"
    },
    "defaultPriorityByHorizon": {
      "today": "Critical",
      "week": "Important",
      "month": "Maintenance"
    },
    "defaultEnergyByDifficulty": {
      "Easy": "Low Energy",
      "Medium": "Standard Focus",
      "Hard": "Deep Focus",
      "Elite": "Deep Focus"
    }
  }
