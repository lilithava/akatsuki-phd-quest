{
  "meta": {
    "name": "Akatsuki PhD Quest - Core Game Rules",
    "version": "2.0.0",
    "description": "Master configuration file for XP progression, leveling, difficulty curves, and game mechanics",
    "author": "Akatsuki System",
    "lastUpdated": "2026-04-18"
  },

  "xpSystem": {
    "enabled": true,
    "xpPerLevel": 500,
    "maxLevel": 99,
    "xpCurve": "linear",
    "curveFormula": "xpForLevel = baseXP * level",
    "notes": "Linear progression: each level requires 500 more XP than the previous",
    
    "levelUpBonuses": {
      "coins": 100,
      "showAnimation": true,
      "playSound": false,
      "unlockNewContent": true
    },
    
    "coinSystem": {
      "enabled": true,
      "coinRatio": 0.2,
      "description": "Each XP earned gives 0.2 coins (20% conversion)",
      "startingCoins": 150
    },
    
    "streakBonuses": {
      "3days": { "xpBonus": 15, "coinBonus": 10 },
      "7days": { "xpBonus": 40, "coinBonus": 25 },
      "14days": { "xpBonus": 100, "coinBonus": 50 },
      "30days": { "xpBonus": 300, "coinBonus": 150 }
    }
  },

  "difficulties": [
    {
      "id": "Easy",
      "label": "Easy",
      "icon": "⭐",
      "timeRangeMinutes": { "min": 5, "max": 20 },
      "cognitiveLoad": "Low",
      "defaultXp": 15,
      "xpRange": { "min": 10, "max": 25 },
      "color": "#2d6a4f",
      "examples": [
        "Write daily mission log",
        "Rename 5 files",
        "Check mission board"
      ]
    },
    {
      "id": "Medium",
      "label": "Medium",
      "icon": "⭐⭐",
      "timeRangeMinutes": { "min": 20, "max": 60 },
      "cognitiveLoad": "Moderate",
      "defaultXp": 35,
      "xpRange": { "min": 25, "max": 55 },
      "color": "#e9c46a",
      "examples": [
        "Summarize one article",
        "Build one mastery check",
        "Publish one daily Skool post"
      ]
    },
    {
      "id": "Hard",
      "label": "Hard",
      "icon": "⭐⭐⭐",
      "timeRangeMinutes": { "min": 60, "max": 180 },
      "cognitiveLoad": "Deep Work",
      "defaultXp": 90,
      "xpRange": { "min": 60, "max": 130 },
      "color": "#e76f51",
      "examples": [
        "Draft 500+ words of a chapter",
        "Code one transcript batch",
        "Outline one L2 master class"
      ]
    },
    {
      "id": "Elite",
      "label": "Elite",
      "icon": "💀",
      "timeRangeMinutes": { "min": 180, "max": 999 },
      "cognitiveLoad": "High Stakes",
      "defaultXp": 250,
      "xpRange": { "min": 150, "max": 500 },
      "color": "#d62828",
      "examples": [
        "Complete full chapter draft",
        "Run full Skool challenge cycle",
        "Finish thematic analysis across a dataset"
      ]
    }
  ],

  "missionTypes": [
    {
      "id": "Mini-Quest",
      "label": "Mini-Quest",
      "icon": "⚡",
      "description": "Tiny, low-friction missions for momentum and re-entry",
      "defaultDifficulty": "Easy",
      "isRepeatable": true,
      "xpMultiplier": 0.8
    },
    {
      "id": "Standard Mission",
      "label": "Standard Mission",
      "icon": "📋",
      "description": "Normal work units with clear outcomes",
      "defaultDifficulty": "Medium",
      "isRepeatable": true,
      "xpMultiplier": 1.0
    },
    {
      "id": "Deep Work Mission",
      "label": "Deep Work",
      "icon": "🎯",
      "description": "Focused blocks for research, writing, or analysis",
      "defaultDifficulty": "Hard",
      "isRepeatable": true,
      "xpMultiplier": 1.2
    },
    {
      "id": "Boss Battle",
      "label": "Boss Battle",
      "icon": "👹",
      "description": "High-stakes milestones and major deliverables",
      "defaultDifficulty": "Elite",
      "isRepeatable": false,
      "xpMultiplier": 1.5,
      "unlockCondition": "Level 5"
    },
    {
      "id": "Recovery Mission",
      "label": "Recovery",
      "icon": "🔄",
      "description": "Repair, reset, and re-entry missions after failure",
      "defaultDifficulty": "Easy",
      "isRepeatable": true,
      "xpMultiplier": 0.6,
      "triggerCondition": "missed_day"
    },
    {
      "id": "Ritual",
      "label": "Ritual",
      "icon": "🌙",
      "description": "Startup, shutdown, and consistency rituals",
      "defaultDifficulty": "Easy",
      "isRepeatable": true,
      "xpMultiplier": 0.7,
      "streakBonus": true
    }
  ],

  "priorityTags": [
    { "id": "Critical", "label": "Critical", "icon": "🔥", "color": "#d62828", "weight": 4 },
    { "id": "Important", "label": "Important", "icon": "⚠️", "color": "#ff8c00", "weight": 3 },
    { "id": "Maintenance", "label": "Maintenance", "icon": "🛠️", "color": "#4a9eff", "weight": 2 },
    { "id": "Optional", "label": "Optional", "icon": "📌", "color": "#888", "weight": 1 }
  ],

  "energyTags": [
    { "id": "Low Energy", "label": "Low Energy", "icon": "😴", "description": "Can be done when tired or mentally drained" },
    { "id": "Standard Focus", "label": "Standard Focus", "icon": "😐", "description": "Normal working state, moderate focus required" },
    { "id": "Deep Focus", "label": "Deep Focus", "icon": "🧠", "description": "Requires uninterrupted, high-focus blocks" }
  ],

  "contextTags": [
    { "id": "Home", "label": "Home", "icon": "🏠" },
    { "id": "Office", "label": "Office", "icon": "🏢" },
    { "id": "Library", "label": "Library", "icon": "📚" },
    { "id": "Online", "label": "Online", "icon": "🌐" },
    { "id": "Skool", "label": "Skool", "icon": "🎓" },
    { "id": "RA", "label": "Research Assistant", "icon": "🔬" },
    { "id": "Writing", "label": "Writing", "icon": "✍️" },
    { "id": "Admin", "label": "Admin", "icon": "📁" }
  ],

  "repeatabilityOptions": [
    { "id": "One-time", "label": "One-time", "icon": "🎯", "resetOn": null },
    { "id": "Daily", "label": "Daily", "icon": "🌅", "resetOn": "midnight" },
    { "id": "Weekly", "label": "Weekly", "icon": "📅", "resetOn": "monday" },
    { "id": "Monthly", "label": "Monthly", "icon": "🌙", "resetOn": "first_day" },
    { "id": "Quarterly", "label": "Quarterly", "icon": "🍂", "resetOn": "quarter_start" }
  ],

  "domains": [
    {
      "id": "PhD",
      "label": "PhD Journey",
      "icon": "🎓",
      "theme": "Shadow Research Missions",
      "color": "#9b59b6",
      "description": "Research, reading, writing, analysis, and dissertation progress"
    },
    {
      "id": "Skool",
      "label": "Skool Community",
      "icon": "👥",
      "theme": "Clan Leadership & Skool Community",
      "color": "#3498db",
      "description": "Community building, content, engagement, and retention"
    },
    {
      "id": "Curriculum",
      "label": "Curriculum Design",
      "icon": "📖",
