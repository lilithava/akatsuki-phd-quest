{
  "meta": {
    "name": "Akatsuki PhD Quest – Core Rules",
    "version": "1.0.0",
    "description": "Global rules, XP logic, streak logic, mission types, difficulty definitions, unlocks, reset rules, and tag enums for the Akatsuki PhD Quest RPG."
  },

  "xpRules": {
    "xpPerLevel": 500,
    "coinRatio": 0.20,
    "levelUpBonusCoins": 100,

    "difficultyXpRanges": {
      "Easy": { "min": 10, "max": 20 },
      "Medium": { "min": 25, "max": 50 },
      "Hard": { "min": 60, "max": 120 },
      "Elite": { "min": 150, "max": 500 }
    },

    "bonuses": {
      "firstCompletion": 10,
      "streak3Days": 15,
      "streak7Days": 40,
      "bossClear": 100,
      "recoveryMission": 15,
      "perfectDocumentation": 10
    }
  },

  "streakRules": {
    "dayCompletedCondition": {
      "description": "A day counts as completed when at least one repeatable mission is finished.",
      "requiresRepeatableTask": true
    },

    "resetTime": "local-midnight",

    "onReset": {
      "regenerateRepeatableTasks": true,
      "clearStepStateForRepeatables": true
    },

    "streakBreakLogic": {
      "ifYesterdayCompleted": "increment",
      "ifYesterdayNotCompleted": "resetToZero"
    },

    "winTheDay": {
      "description": "1 important mission + 1 ritual + 1 documentation action.",
      "requirements": {
        "importantMissions": 1,
        "ritualMissions": 1,
        "documentationMissions": 1
      }
    }
  },

  "missionTypes": [
    "Mini-Quest",
    "Standard Mission",
    "Deep Work Mission",
    "Boss Battle",
    "Recovery Mission",
    "Secret Mission",
    "Ritual"
  ],

  "difficulties": [
    {
      "id": "Easy",
      "timeRangeMinutes": { "min": 5, "max": 15 },
      "cognitiveLoad": "Low",
      "defaultXp": 15
    },
    {
      "id": "Medium",
      "timeRangeMinutes": { "min": 20, "max": 60 },
      "cognitiveLoad": "Moderate",
      "defaultXp": 35
    },
    {
      "id": "Hard",
      "timeRangeMinutes": { "min": 60, "max": 180 },
      "cognitiveLoad": "Deep Work",
      "defaultXp": 90
    },
    {
      "id": "Elite",
      "timeRangeMinutes": { "min": 180, "max": 999 },
      "cognitiveLoad": "High Stakes",
      "defaultXp": 250
    }
  ],

  "repeatabilityOptions": [
    "One-time",
    "Repeatable",
    "Daily",
    "Weekly",
    "Monthly",
    "Quarterly"
  ],

  "priorityTags": [
    "Critical",
    "Important",
    "Maintenance",
    "Optional"
  ],

  "energyTags": [
    "Low Energy",
    "Standard Focus",
    "Deep Focus"
  ],

  "contextTags": [
    "Home",
    "Office",
    "Library",
    "Online",
    "Skool",
    "RA",
    "Writing",
    "Admin"
  ],

  "domains": [
    "PhD",
    "Skool",
    "Curriculum",
    "Research Assistantship",
    "Documentation",
    "Rituals",
    "Boss",
    "Recovery"
  ],

  "themes": [
    "Shadow Research Missions",
    "Village Knowledge Expansion",
    "Clan Leadership & Skool Community",
    "Intelligence Gathering",
    "Eternal Documentation Scrolls",
    "Discipline & Rituals",
    "Boss Battles",
    "Recovery & Reset Protocols"
  ],

  "resetRules": {
    "localStorageKeys": {
      "xp": "ak_xp",
      "level": "ak_level",
      "coins": "ak_coins",
      "streak": "ak_streak",
      "sections": "ak_sections",
      "shop": "ak_shop",
      "avatar": "ak_avatar",
      "bank": "ak_bank",
      "undo": "ak_undo",
      "sidebarHidden": "ak_sidebar_hidden",
      "lastResetDate": "ak_last_reset_date",
      "dayCompletedPrefix": "ak_day_completed_",
      "stepsPrefix": "ak_steps_"
    },

    "antiOverwhelmRules": {
      "maxActiveEliteMissions": 3,

      "backlogTriageTrigger": {
        "missedTasksInDomain": 3,
        "createsMissionType": "Backlog Triage"
      },

      "overwhelmResetTrigger": {
        "brokenStreaksInWeek": 2,
        "createsMissionType": "Overwhelm Reset Protocol"
      }
    }
  },

  "unlockRules": {
    "levels": [
      { "level": 1, "unlocks": ["Mini-Quests", "Rituals"] },
      { "level": 3, "unlocks": ["Standard Missions", "Community Missions"] },
      { "level": 4, "unlocks": ["Documentation Bonuses", "Streak Multipliers"] },
      { "level": 5, "unlocks": ["Hard Missions", "First Boss Battles"] },
      { "level": 7, "unlocks": ["Secret Missions"] },
      { "level": 10, "unlocks": ["Elite Boss Track"] },
      { "level": 12, "unlocks": ["Custom Mission Creation"] },
      { "level": 15, "unlocks": ["Akatsuki Commander Status"] }
    ]
  },

  "achievementRefs": {
    "file": "achievements.json",
    "ids": [
      "first_blood",
      "scroll_keeper",
      "shadow_scholar",
      "data_hunter",
      "clan_builder",
      "master_architect",
      "signal_interceptor",
      "no_loose_ends",
      "boss_slayer",
      "resurrection_protocol",
      "crimson_streak",
      "akatsuki_commander"
    ]
  },

  "shopRules": {
    "itemsFile": "shop-items.json",
    "maxEquippedPerType": 1,
    "bonusTypes": [
      "xpMultiplier",
      "coinMultiplier",
      "streakProtection",
      "documentationBonus",
      "bossXpBoost"
    ]
  },

  "avatarRules": {
    "layersFile": "avatar-layers.json",
    "editableName": true,
    "defaultName": "Shadow Scholar",
    "baseStats": {
      "xpMultiplier": 1.0,
      "coinMultiplier": 1.0
    }
  }
}
