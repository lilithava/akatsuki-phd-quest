/**
 * Akatsuki Avatar System
 * Combined: Avatar Data + Renderer
 * Version: 2.0.0
 * 
 * This file contains both the avatar data definitions and the rendering engine.
 * Equipment from shop affects visual appearance, achievements unlock features.
 */

// ============================================================
// AVATAR DATA CONFIGURATION
// ============================================================

const AVATAR_CONFIG = {
  meta: {
    name: "Akatsuki Avatar System",
    version: "2.0.0",
    description: "Modular SVG-based avatar system with equipable slots and visual customization",
    lastUpdated: "2026-04-18"
  },

  avatarDefaults: {
    baseName: "Shadow Scholar",
    defaultVariant: "bauhaus",
    defaultColors: {
      skin: "#e8c4a0",
      hair: "#1a1a1a",
      outfit: "#1a1a2e",
      accent: "#d62828"
    },
    size: 200,
    viewBox: "0 0 200 200"
  },

  avatarSlots: [
    { id: "body", name: "Body Type", icon: "👤", required: true, maxItems: 1 },
    { id: "cloak", name: "Cloak", icon: "🧥", required: false, maxItems: 1, unlockLevel: 1 },
    { id: "mask", name: "Mask", icon: "🎭", required: false, maxItems: 1, unlockLevel: 3 },
    { id: "headwear", name: "Headwear", icon: "👒", required: false, maxItems: 1, unlockLevel: 5 },
    { id: "companion", name: "Companion", icon: "🐺", required: false, maxItems: 1, unlockLevel: 7 },
    { id: "aura", name: "Aura", icon: "✨", required: false, maxItems: 1, unlockLevel: 10 },
    { id: "accessory_left", name: "Left Accessory", icon: "💍", required: false, maxItems: 1 },
    { id: "accessory_right", name: "Right Accessory", icon: "⚔️", required: false, maxItems: 1 }
  ],

  bodyTypes: {
    standard: { name: "Standard", skinTone: "#e8c4a0", shadowTone: "#c49a6c", blendshapes: { height: 0, width: 0 } },
    tall: { name: "Tall", skinTone: "#e8c4a0", shadowTone: "#c49a6c", blendshapes: { height: 20, width: 0 }, unlockLevel: 5 },
    athletic: { name: "Athletic", skinTone: "#d4a574", shadowTone: "#b8895a", blendshapes: { height: 5, width: 10 }, unlockLevel: 8 }
  },

  facialFeatures: {
    eyes: {
      default: { name: "Default Eyes", svg: "ellipse" },
      sharingan: { name: "Sharingan Eyes", unlockAchievement: "shadow_scholar", color: "#d62828" },
      byakugan: { name: "Byakugan Eyes", unlockLevel: 15, color: "#9b59b6" },
      tired: { name: "Tired Eyes", unlockStreak: 30, color: "#8b0000" }
    },
    mouth: {
      neutral: { name: "Neutral", path: "M 90 100 Q 100 103 110 100" },
      smile: { name: "Smile", path: "M 88 100 Q 100 112 112 100" },
      determined: { name: "Determined", path: "M 88 100 L 100 108 L 112 100" }
    },
    eyebrows: {
      default: { name: "Default", leftPath: "M 74 65 Q 82 62 90 65", rightPath: "M 126 65 Q 118 62 110 65" },
      angry: { name: "Angry", leftPath: "M 72 65 Q 82 60 88 68", rightPath: "M 128 65 Q 118 60 112 68" }
    }
  },

  colorOptions: {
    skin: [
      { id: "fair", name: "Fair", value: "#f5d0a9" },
      { id: "tan", name: "Tan", value: "#d4a574" },
      { id: "dark", name: "Dark", value: "#8b5a2b" },
      { id: "shadow", name: "Shadow", value: "#2a2a2e", unlockLevel: 20 }
    ],
    hair: [
      { id: "black", name: "Black", value: "#1a1a1a" },
      { id: "white", name: "White", value: "#e6e6e6" },
      { id: "red", name: "Crimson", value: "#d62828", unlockAchievement: "crimson_streak" },
      { id: "blue", name: "Midnight Blue", value: "#1a2a4a", unlockLevel: 12 }
    ],
    outfit: [
      { id: "akatsuki", name: "Akatsuki Red", value: "#d62828" },
      { id: "shadow", name: "Shadow Black", value: "#0a0a0c" },
      { id: "crimson_glow", name: "Crimson Glow", value: "#ff4444", unlockItem: "crimson_aura" }
    ]
  },

  layerOrder: ["background", "body", "outfit", "cloak", "accessories", "mask", "headwear", "companion", "aura", "effects"]
};

// ============================================================
// AVATAR RENDERER CLASS
// ============================================================

class AkatsukiAvatarRenderer {
  constructor(options = {}) {
    this.container = options.container || document.getElementById('avatarContainer');
    this.onEquip = options.onEquip || null;
    this.onUnequip = options.onUnequip || null;
    
    this.state = {
      name: options.name || AVATAR_CONFIG.avatarDefaults.baseName,
      bodyType: options.bodyType || 'standard',
      eyes: options.eyes || 'default',
      mouth: options.mouth || 'neutral',
      eyebrows: options.eyebrows || 'default',
      colors: {
        skin: options.skinColor || AVATAR_CONFIG.avatarDefaults.defaultColors.skin,
        hair: options.hairColor || AVATAR_CONFIG.avatarDefaults.defaultColors.hair,
        outfit: options.outfitColor || AVATAR_CONFIG.avatarDefaults.defaultColors.outfit,
        accent: options.accentColor || AVATAR_CONFIG.avatarDefaults.defaultColors.accent
      },
      equipped: options.equipped || [],
      unlockedFeatures: options.unlockedFeatures || [],
      currentAnimation: null
    };
    
    this.svg = null;
    this.defs = null;
    this.animationFrame = null;
  }

  /**
   * Initialize the renderer
   */
  init() {
    this.createSVGContainer();
    this.render();
    return this;
  }

  /**
   * Create the main SVG element
   */
  createSVGContainer() {
    this.svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    this.svg.setAttribute('width', AVATAR_CONFIG.avatarDefaults.size);
    this.svg.setAttribute('height', AVATAR_CONFIG.avatarDefaults.size);
    this.svg.setAttribute('viewBox', AVATAR_CONFIG.avatarDefaults.viewBox);
    this.svg.style.backgroundColor = 'transparent';
    
    this.defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
    this.svg.appendChild(this.defs);
    
    if (this.container) {
      this.container.innerHTML = '';
      this.container.appendChild(this.svg);
    }
  }

  /**
   * Main render method - draws all layers in order
   */
  render() {
    if (!this.svg) return;
    
    // Clear previous render (keep defs)
    const children = Array.from(this.svg.children);
    children.forEach(child => {
      if (child !== this.defs) {
        this.svg.removeChild(child);
      }
    });
    
    // Render layers in defined order
    AVATAR_CONFIG.layerOrder.forEach(layer => {
      switch(layer) {
        case 'background': this.renderBackground(); break;
        case 'body': this.renderBody(); break;
        case 'outfit': this.renderOutfit(); break;
        case 'cloak': this.renderCloak(); break;
        case 'accessories': this.renderAccessories(); break;
        case 'mask': this.renderMask(); break;
        case 'headwear': this.renderHeadwear(); break;
        case 'companion': this.renderCompanion(); break;
        case 'aura': this.renderAura(); break;
        case 'effects': this.renderEffects(); break;
      }
    });
    
    this.addIdleAnimation();
  }

  /**
   * Render background circle
   */
  renderBackground() {
    const bg = this.createSVGElement('circle', {
      cx: 100, cy: 100, r: 90,
      fill: '#1a1a2e',
      stroke: this.state.colors.accent,
      strokeWidth: 3
    });
    this.svg.appendChild(bg);
  }

  /**
   * Render body with facial features
   */
  renderBody() {
    const bodyType = AVATAR_CONFIG.bodyTypes[this.state.bodyType] || AVATAR_CONFIG.bodyTypes.standard;
    const skinColor = this.state.colors.skin;
    
    // Head
    const head = this.createSVGElement('circle', {
      cx: 100, cy: 85, r: 35,
      fill: skinColor
    });
    this.svg.appendChild(head);
    
    // Torso
    const torso = this.createSVGElement('path', {
      d: 'M 75 120 L 75 170 Q 100 185 125 170 L 125 120 Z',
      fill: skinColor
    });
    this.svg.appendChild(torso);
    
    // Arms
    const leftArm = this.createSVGElement('path', {
      d: 'M 75 125 L 65 160 L 70 165',
      fill: 'none',
      stroke: skinColor,
      strokeWidth: 12,
      strokeLinecap: 'round'
    });
    this.svg.appendChild(leftArm);
    
    const rightArm = this.createSVGElement('path', {
      d: 'M 125 125 L 135 160 L 130 165',
      fill: 'none',
      stroke: skinColor,
      strokeWidth: 12,
      strokeLinecap: 'round'
    });
    this.svg.appendChild(rightArm);
    
    // Facial features
    this.renderEyes();
    this.renderMouth();
    this.renderEyebrows();
  }

  /**
   * Render eyes based on selected type
   */
  renderEyes() {
    const eyeType = this.state.eyes;
    const eyeConfig = AVATAR_CONFIG.facialFeatures.eyes[eyeType] || AVATAR_CONFIG.facialFeatures.eyes.default;
    
    if (eyeType === 'sharingan') {
      this.renderSharinganEyes();
    } else if (eyeType === 'byakugan') {
      this.renderByakuganEyes();
    } else {
      // Default eyes
      const leftEye = this.createSVGElement('ellipse', { cx: 82, cy: 78, rx: 7, ry: 9, fill: '#2a2a2e' });
      const rightEye = this.createSVGElement('ellipse', { cx: 118, cy: 78, rx: 7, ry: 9, fill: '#2a2a2e' });
      const leftHighlight = this.createSVGElement('circle', { cx: 80, cy: 75, r: 2, fill: '#fff' });
      const rightHighlight = this.createSVGElement('circle', { cx: 116, cy: 75, r: 2, fill: '#fff' });
      
      this.svg.appendChild(leftEye);
      this.svg.appendChild(rightEye);
      this.svg.appendChild(leftHighlight);
      this.svg.appendChild(rightHighlight);
    }
  }

  /**
   * Render Sharingan eyes (achievement reward)
   */
  renderSharinganEyes() {
    // Create pattern
    const pattern = this.createSVGElement('pattern', {
      id: 'sharingan', width: 20, height: 20, patternUnits: 'userSpaceOnUse'
    });
    const circle = this.createSVGElement('circle', { cx: 10, cy: 10, r: 8, fill: '#d62828' });
    pattern.appendChild(circle);
    this.defs.appendChild(pattern);
    
    const leftEye = this.createSVGElement('ellipse', { cx: 82, cy: 78, rx: 8, ry: 10, fill: 'url(#sharingan)' });
    const rightEye = this.createSVGElement('ellipse', { cx: 118, cy: 78, rx: 8, ry: 10, fill: 'url(#sharingan)' });
    this.svg.appendChild(leftEye);
    this.svg.appendChild(rightEye);
  }

  /**
   * Render Byakugan eyes
   */
  renderByakuganEyes() {
    const leftEye = this.createSVGElement('ellipse', {
      cx: 82, cy: 78, rx: 9, ry: 11, fill: '#e6e6e6', stroke: '#9b59b6', strokeWidth: 1.5
    });
    const rightEye = this.createSVGElement('ellipse', {
      cx: 118, cy: 78, rx: 9, ry: 11, fill: '#e6e6e6', stroke: '#9b59b6', strokeWidth: 1.5
    });
    this.svg.appendChild(leftEye);
    this.svg.appendChild(rightEye);
  }

  /**
   * Render mouth
   */
  renderMouth() {
    const mouthType = this.state.mouth;
    const mouthConfig = AVATAR_CONFIG.facialFeatures.mouth[mouthType] || AVATAR_CONFIG.facialFeatures.mouth.neutral;
    
    const mouth = this.createSVGElement('path', {
      d: mouthConfig.path,
      fill: 'none',
      stroke: '#2a2a2e',
      strokeWidth: 2,
      strokeLinecap: 'round'
    });
    this.svg.appendChild(mouth);
  }

  /**
   * Render eyebrows
   */
  renderEyebrows() {
    const browType = this.state.eyebrows;
    const browConfig = AVATAR_CONFIG.facialFeatures.eyebrows[browType] || AVATAR_CONFIG.facialFeatures.eyebrows.default;
    const hairColor = this.state.colors.hair;
    
    const leftBrow = this.createSVGElement('path', {
      d: browConfig.leftPath,
      fill: 'none',
      stroke: hairColor,
      strokeWidth: 3,
      strokeLinecap: 'round'
    });
    const rightBrow = this.createSVGElement('path', {
      d: browConfig.rightPath,
      fill: 'none',
      stroke: hairColor,
      strokeWidth: 3,
      strokeLinecap: 'round'
    });
    this.svg.appendChild(leftBrow);
    this.svg.appendChild(rightBrow);
  }

  /**
   * Render outfit/clothing
   */
  renderOutfit() {
    const outfitColor = this.state.colors.outfit;
    
    const shirt = this.createSVGElement('path', {
      d: 'M 70 130 L 70 175 Q 100 190 130 175 L 130 130 Z',
      fill: outfitColor
    });
    this.svg.appendChild(shirt);
    
    // Collar detail
    const collar = this.createSVGElement('path', {
      d: 'M 85 130 L 100 145 L 115 130',
      fill: 'none',
      stroke: this.state.colors.accent,
      strokeWidth: 2
    });
    this.svg.appendChild(collar);
  }

  /**
   * Render cloak (if equipped)
   */
  renderCloak() {
    const hasCloak = this.isEquipped('cloak');
    if (!hasCloak) return;
    
    const cloak = this.createSVGElement('path', {
      d: 'M 50 120 Q 50 60 100 55 Q 150 60 150 120 L 155 180 Q 100 195 45 180 Z',
      fill: 'rgba(214, 40, 40, 0.3)',
      stroke: this.state.colors.accent,
      strokeWidth: 1.5
    });
    this.svg.appendChild(cloak);
    
    // Red clouds pattern
    for (let i = 0; i < 3; i++) {
      const cloud = this.createSVGElement('circle', {
        cx: 80 + (i * 30), cy: 150, r: 8,
        fill: this.state.colors.accent,
        opacity: 0.6
      });
      this.svg.appendChild(cloud);
    }
  }

  /**
   * Render accessories
   */
  renderAccessories() {
    // Ring (left accessory)
    if (this.isEquipped('accessory_left')) {
      const ring = this.createSVGElement('circle', {
        cx: 65, cy: 165, r: 6,
        fill: 'none', stroke: '#ffd700', strokeWidth: 2
      });
      this.svg.appendChild(ring);
    }
    
    // Weapon (right accessory)
    if (this.isEquipped('accessory_right')) {
      const weapon = this.createSVGElement('path', {
        d: 'M 135 155 L 155 135 M 145 165 L 165 145',
        stroke: '#c0c0c0', strokeWidth: 2
      });
      this.svg.appendChild(weapon);
    }
  }

  /**
   * Render mask
   */
  renderMask() {
    const hasMask = this.isEquipped('mask');
    if (!hasMask) return;
    
    const mask = this.createSVGElement('path', {
      d: 'M 72 60 Q 100 50 128 60 L 125 95 Q 100 105 75 95 Z',
      fill: '#e6e6e6', stroke: '#888', strokeWidth: 1
    });
    this.svg.appendChild(mask);
    
    // Mask eye holes
    const leftHole = this.createSVGElement('ellipse', { cx: 85, cy: 78, rx: 6, ry: 8, fill: '#2a2a2e' });
    const rightHole = this.createSVGElement('ellipse', { cx: 115, cy: 78, rx: 6, ry: 8, fill: '#2a2a2e' });
    this.svg.appendChild(leftHole);
    this.svg.appendChild(rightHole);
  }

  /**
   * Render headwear
   */
  renderHeadwear() {
    const hasHeadwear = this.isEquipped('headwear');
    if (!hasHeadwear) return;
    
    const headband = this.createSVGElement('path', {
      d: 'M 65 50 Q 100 40 135 50 L 133 58 Q 100 50 67 58 Z',
      fill: '#2a2a2e', stroke: this.state.colors.accent, strokeWidth: 1.5
    });
    this.svg.appendChild(headband);
    
    const plate = this.createSVGElement('rect', {
      x: 88, y: 44, width: 24, height: 12, rx: 2,
      fill: this.state.colors.accent
    });
    this.svg.appendChild(plate);
  }

  /**
   * Render companion
   */
  renderCompanion() {
    const companionItem = this.getEquippedItem('companion');
    if (!companionItem) return;
    
    if (companionItem === 'companion_raven') {
      this.renderRaven();
    } else if (companionItem === 'companion_wolf') {
      this.renderWolf();
    }
  }

  /**
   * Render raven companion
   */
  renderRaven() {
    const ravenGroup = this.createSVGElement('g', { transform: 'translate(150, 50)' });
    
    const body = this.createSVGElement('ellipse', { cx: 10, cy: 15, rx: 12, ry: 8, fill: '#1a1a1a' });
    const head = this.createSVGElement('circle', { cx: 22, cy: 12, r: 6, fill: '#1a1a1a' });
    const eye = this.createSVGElement('circle', { cx: 24, cy: 11, r: 1.5, fill: this.state.colors.accent });
    
    ravenGroup.appendChild(body);
    ravenGroup.appendChild(head);
    ravenGroup.appendChild(eye);
    this.svg.appendChild(ravenGroup);
  }

  /**
   * Render wolf companion
   */
  renderWolf() {
    const wolfGroup = this.createSVGElement('g', { transform: 'translate(35, 140)' });
    
    const body = this.createSVGElement('ellipse', { cx: 15, cy: 10, rx: 14, ry: 8, fill: '#4a4a5a' });
    const head = this.createSVGElement('polygon', { points: '28,5 35,10 28,15', fill: '#4a4a5a' });
    const eye = this.createSVGElement('circle', { cx: 31, cy: 9, r: 1.5, fill: this.state.colors.accent });
    
    wolfGroup.appendChild(body);
    wolfGroup.appendChild(head);
    wolfGroup.appendChild(eye);
    this.svg.appendChild(wolfGroup);
  }

  /**
   * Render aura
   */
  renderAura() {
    const hasAura = this.isEquipped('aura');
    if (!hasAura) return;
    
    const aura = this.createSVGElement('circle', {
      cx: 100, cy: 100, r: 95,
      fill: 'none', stroke: this.state.colors.accent, strokeWidth: 2,
      strokeDasharray: '8, 8', opacity: 0.6
    });
    
    const animate = this.createSVGElement('animate', {
      attributeName: 'opacity', values: '0.3;0.8;0.3', dur: '2s', repeatCount: 'indefinite'
    });
    aura.appendChild(animate);
    this.svg.appendChild(aura);
  }

  /**
   * Render visual effects (level up, achievement)
   */
  renderEffects() {
    if (this.state.currentAnimation === 'level_up') {
      this.renderLevelUpEffect();
    }
  }

  /**
   * Render level up celebration effect
   */
  renderLevelUpEffect() {
    for (let i = 0; i < 12; i++) {
      const angle = (i * 30) * Math.PI / 180;
      const x = 100 + Math.cos(angle) * 70;
      const y = 100 + Math.sin(angle) * 70;
      
      const star = this.createSVGElement('polygon', {
        points: `${x},${y-3} ${x+2},${y-1} ${x+4},${y} ${x+2},${y+1} ${x},${y+3} ${x-2},${y+1} ${x-4},${y} ${x-2},${y-1}`,
        fill: '#ffd700'
      });
      
      const animate = this.createSVGElement('animate', {
        attributeName: 'opacity', values: '1;0', dur: '1s', fill: 'freeze'
      });
      star.appendChild(animate);
      this.svg.appendChild(star);
    }
    
    setTimeout(() => {
      this.state.currentAnimation = null;
      this.render();
    }, 1000);
  }

  /**
   * Add floating idle animation
   */
  addIdleAnimation() {
    const animate = this.createSVGElement('animateTransform', {
      attributeName: 'transform', type: 'translate',
      values: '0,0; 0,-3; 0,0', dur: '3s', repeatCount: 'indefinite'
    });
    this.svg.appendChild(animate);
  }

  /**
   * Helper to create SVG elements
   */
  createSVGElement(tag, attributes) {
    const element = document.createElementNS('http://www.w3.org/2000/svg', tag);
    Object.keys(attributes).forEach(key => {
      element.setAttribute(key, attributes[key]);
    });
    return element;
  }

  /**
   * Check if an item in a slot is equipped
   */
  isEquipped(slot) {
    return this.state.equipped.some(itemId => {
      const item = SHOP_ITEMS?.find(i => i.id === itemId);
      return item && item.slot === slot;
    });
  }

  /**
   * Get the equipped item ID for a slot
   */
  getEquippedItem(slot) {
    const item = this.state.equipped.find(itemId => {
      const shopItem = SHOP_ITEMS?.find(i => i.id === itemId);
      return shopItem && shopItem.slot === slot;
    });
    return item || null;
  }

  /**
   * Update avatar name
   */
  setName(name) {
    this.state.name = name;
    return this;
  }

  /**
   * Update body type
   */
  setBodyType(type) {
    if (AVATAR_CONFIG.bodyTypes[type]) {
      this.state.bodyType = type;
      this.render();
    }
    return this;
  }

  /**
   * Update eye type
   */
  setEyes(type) {
    if (AVATAR_CONFIG.facialFeatures.eyes[type]) {
      this.state.eyes = type;
      this.render();
    }
    return this;
  }

  /**
   * Update mouth type
   */
  setMouth(type) {
    if (AVATAR_CONFIG.facialFeatures.mouth[type]) {
      this.state.mouth = type;
      this.render();
    }
    return this;
  }

  /**
   * Update eyebrow type
   */
  setEyebrows(type) {
    if (AVATAR_CONFIG.facialFeatures.eyebrows[type]) {
      this.state.eyebrows = type;
      this.render();
    }
    return this;
  }

  /**
   * Update color
   */
  setColor(type, value) {
    if (this.state.colors[type]) {
      this.state.colors[type] = value;
      this.render();
    }
    return this;
  }

  /**
   * Update equipped items
   */
  setEquipped(equippedItems) {
    this.state.equipped = equippedItems;
    this.render();
    return this;
  }

  /**
   * Trigger level up animation
   */
  triggerLevelUp() {
    this.state.currentAnimation = 'level_up';
    this.render();
    return this;
  }

  /**
   * Export avatar as SVG string
   */
  exportSVG() {
    const serializer = new XMLSerializer();
    return serializer.serializeToString(this.svg);
  }

  /**
   * Export avatar as PNG (requires canvas)
   */
  async exportPNG() {
    const svgString = this.exportSVG();
    const blob = new Blob([svgString], { type: 'image/svg+xml' });
    const url = URL.createObjectURL(blob);
    const img = new Image();
    
    return new Promise((resolve) => {
      img.onload = () => {
        const canvas = document.createElement('canvas');
        canvas.width = AVATAR_CONFIG.avatarDefaults.size;
        canvas.height = AVATAR_CONFIG.avatarDefaults.size;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0);
        URL.revokeObjectURL(url);
        resolve(canvas.toDataURL('image/png'));
      };
      img.src = url;
    });
  }

  /**
   * Get current state (for saving)
   */
  getState() {
    return {
      name: this.state.name,
      bodyType: this.state.bodyType,
      eyes: this.state.eyes,
      mouth: this.state.mouth,
      eyebrows: this.state.eyebrows,
      colors: { ...this.state.colors },
      equipped: [...this.state.equipped]
    };
  }

  /**
   * Load state from saved data
   */
  loadState(savedState) {
    if (savedState.name) this.state.name = savedState.name;
    if (savedState.bodyType) this.state.bodyType = savedState.bodyType;
    if (savedState.eyes) this.state.eyes = savedState.eyes;
    if (savedState.mouth) this.state.mouth = savedState.mouth;
    if (savedState.eyebrows) this.state.eyebrows = savedState.eyebrows;
    if (savedState.colors) this.state.colors = { ...this.state.colors, ...savedState.colors };
    if (savedState.equipped) this.state.equipped = [...savedState.equipped];
    this.render();
    return this;
  }
}

// Export for use in main script
