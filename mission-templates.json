{
  "meta": {
    "name": "Akatsuki Mission Templates",
    "version": "1.0.0",
    "description": "Reusable mission templates for the Task Generator. Each template defines structure, micro-steps, difficulty defaults, and domain/theme mappings."
  },

  "templates": [

    /* ============================================================
       PH.D — RESEARCH / WRITING / ANALYSIS
    ============================================================ */

    {
      "id": "phd_read_article",
      "label": "Read & Annotate Article",
      "domain": "PhD",
      "theme": "Shadow Research Missions",
      "defaultDifficulty": "Medium",
      "missionType": "Standard Mission",
      "estimatedTime": 40,
      "microSteps": [
        "Open the article and scan abstract + conclusion.",
        "Identify the research question and theoretical frame.",
        "Highlight 3–5 key arguments or findings.",
        "Capture 3 synthesis bullets in your notes.",
        "Save citation + PDF in your source bank."
      ],
      "successCriteria": "Article annotated with clear takeaways.",
      "failureCondition": "Reading without capturing notes.",
      "tags": ["reading", "annotation", "literature"]
    },

    {
      "id": "phd_write_section",
      "label": "Draft Section (500–700 words)",
      "domain": "PhD",
      "theme": "Shadow Research Missions",
      "defaultDifficulty": "Hard",
      "missionType": "Deep Work Mission",
      "estimatedTime": 90,
      "microSteps": [
        "Open outline and choose one subsection.",
        "Gather relevant notes and citations.",
        "Write topic sentence + argument frame.",
        "Draft 2–3 evidence paragraphs.",
        "Write synthesis + transition sentence.",
        "Save version and log progress."
      ],
      "successCriteria": "500+ usable words added to draft.",
      "failureCondition": "Editing outline without drafting prose.",
      "tags": ["writing", "drafting", "deep-work"]
    },

    {
      "id": "phd_analysis_batch",
      "label": "Analyze Data Batch",
      "domain": "PhD",
      "theme": "Shadow Research Missions",
      "defaultDifficulty": "Hard",
      "missionType": "Deep Work Mission",
      "estimatedTime": 120,
      "microSteps": [
        "Open dataset or transcript batch.",
        "Review coding scheme or analytic frame.",
        "Apply codes or analytic categories.",
        "Write memo capturing emerging patterns.",
        "Save coded batch + memo in analysis folder."
      ],
      "successCriteria": "Batch coded + memo written.",
      "failureCondition": "Reading without coding or memoing.",
      "tags": ["analysis", "coding", "deep-work"]
    },

