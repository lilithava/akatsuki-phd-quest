      "missionType": "Recovery Mission",
      "estimatedTime": 20,
      "microSteps": [
        "List all overdue missions.",
        "Mark 1–2 that matter most.",
        "Convert heavy missions into smaller tasks.",
        "Archive or defer low-value items.",
        "Commit to one re-entry action."
      ],
      "successCriteria": "Backlog reduced + clarity restored.",
