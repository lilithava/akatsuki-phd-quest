{
  "meta": {
    "name": "Akatsuki Mission Templates",
    "version": "2.0.0",
    "description": "Reusable mission templates for the Task Generator. Each template defines structure, micro-steps, and dynamic generation rules.",
    "lastUpdated": "2026-04-18"
  },

  "templateCategories": [
    { "id": "research", "name": "Research Tasks", "icon": "🔬", "defaultDomain": "PhD" },
    { "id": "teaching", "name": "Teaching & Curriculum", "icon": "📖", "defaultDomain": "Curriculum" },
    { "id": "community", "name": "Community Building", "icon": "👥", "defaultDomain": "Skool" },
    { "id": "documentation", "name": "Documentation", "icon": "📝", "defaultDomain": "Documentation" },
    { "id": "rituals", "name": "Discipline Rituals", "icon": "🌙", "defaultDomain": "Rituals" }
  ],

  "templates": [
    {
      "id": "research_literature_review",
      "name": "Literature Review Mission",
      "category": "research",
      "icon": "📚",
      "description": "Find, read, and synthesize academic sources",
      "unlockAtLevel": 1,
      "defaultDifficulty": "Medium",
      "defaultPriority": "Critical",
      "defaultEnergy": "Standard Focus",
      "estimatedTime": 90,
      "xpRange": { "min": 35, "max": 85 },
      
      "dynamicSteps": {
        "base": [
          "Define research question and scope",
          "Search academic databases for relevant sources",
          "Screen abstracts and select ${sourceCount} key articles",
          "Read and annotate selected sources",
          "Extract key quotes and arguments",
          "Write synthesis connecting the sources",
          "Identify gaps and future research directions",
          "Save citations to reference manager"
        ],
        "variables": {
          "sourceCount": { "type": "select", "options": [5, 10, 15, 20], "default": 10 }
        }
      },
      
      "successCriteria": "${sourceCount} sources annotated with synthesis notes",
      "failureCondition": "Sources collected but not read or annotated",
      "reward": "+${xpGain} XP, research progress",
      "recoveryMission": "Read and annotate 1 source only",
      "tags": ["literature", "research", "reading"]
    },

    {
      "id": "research_data_analysis",
      "name": "Data Analysis Mission",
      "category": "research",
      "icon": "📊",
      "description": "Code, analyze, and interpret research data",
      "unlockAtLevel": 3,
      "defaultDifficulty": "Hard",
      "defaultPriority": "Critical",
      "defaultEnergy": "Deep Focus",
      "estimatedTime": 120,
      "xpRange": { "min": 60, "max": 120 },
      
      "dynamicSteps": {
        "base": [
          "Review codebook and analysis framework",
          "Open ${dataType} dataset",
          "Apply codes to ${pageCount} pages/items",
          "Write analytic memos on emerging patterns",
          "Identify ${themeCount} key themes",
          "Find supporting quotes for each theme",
          "Draft preliminary findings section"
        ],
        "variables": {
          "dataType": { "type": "select", "options": ["transcript", "survey", "field notes", "archival"], "default": "transcript" },
          "pageCount": { "type": "range", "min": 5, "max": 30, "default": 10 },
          "themeCount": { "type": "range", "min": 3, "max": 7, "default": 5 }
        }
      },
      
      "successCriteria": "${pageCount} pages coded with ${themeCount} themes identified",
      "failureCondition": "Data reviewed without coding or memoing",
      "reward": "+${xpGain} XP, analysis progress",
      "recoveryMission": "Code 2 pages and write 1 memo",
      "tags": ["analysis", "coding", "qualitative"]
    },

    {
      "id": "community_daily_post",
      "name": "Daily Community Post",
      "category": "community",
      "icon": "📢",
      "description": "Create engaging content for Skool community",
      "unlockAtLevel": 1,
      "defaultDifficulty": "Easy",
      "defaultPriority": "Important",
      "defaultEnergy": "Standard Focus",
      "estimatedTime": 30,
      "repeatability": "Daily",
      "xpRange": { "min": 15, "max": 35 },
      
      "dynamicSteps": {
        "base": [
          "Choose ${postType} as today's focus",
          "Write attention-grabbing hook sentence",
          "Add ${tipCount} actionable teaching points",
          "Include ${exampleCount} real examples",
          "Add call-to-action for member engagement",
          "Publish post and pin if appropriate",
          "Respond to first ${responseCount} comments"
        ],
        "variables": {
          "postType": { "type": "select", "options": ["lesson", "question", "challenge", "resource", "win spotlight"], "default": "lesson" },
          "tipCount": { "type": "range", "min": 2, "max": 5, "default": 3 },
          "exampleCount": { "type": "range", "min": 1, "max": 3, "default": 2 },
          "responseCount": { "type": "range", "min": 1, "max": 5, "default": 3 }
        }
      },
      
      "successCriteria": "Post published with ${tipCount} tips and member engagement",
      "failureCondition": "Posting vague or low-value content",
      "reward": "+${xpGain} XP, community streak",
      "recoveryMission": "Publish 1 concise takeaway post",
      "tags": ["content", "engagement", "daily"]
    },

    {
      "id": "teaching_lesson_design",
      "name": "Lesson Design Mission",
      "category": "teaching",
      "icon": "📝",
      "description": "Create complete lesson or module",
      "unlockAtLevel": 2,
      "defaultDifficulty": "Medium",
      "defaultPriority": "Important",
      "defaultEnergy": "Standard Focus",
      "estimatedTime": 90,
      "xpRange": { "min": 40, "max": 80 },
      
      "dynamicSteps": {
        "base": [
          "Define ${outcomeCount} measurable learning outcomes",
          "Design hook and opening activity",
          "Create ${sectionCount} main teaching sections",
          "Develop ${activityCount} practice activities",
          "Build assessment to measure mastery",
          "Create ${slideCount} supporting slides/visuals",
          "Write instructor notes and timing guide"
        ],
        "variables": {
          "outcomeCount": { "type": "range", "min": 3, "max": 6, "default": 4 },
          "sectionCount": { "type": "range", "min": 2, "max": 5, "default": 3 },
          "activityCount": { "type": "range", "min": 2, "max": 4, "default": 3 },
          "slideCount": { "type": "range", "min": 5, "max": 15, "default": 10 }
        }
      },
      
      "successCriteria": "Complete lesson with ${outcomeCount} outcomes and assessments",
      "failureCondition": "Lesson outline without detailed activities",
      "reward": "+${xpGain} XP, curriculum progress",
      "recoveryMission": "Write outcomes and outline only",
      "tags": ["curriculum", "teaching", "design"]
    },

    {
      "id": "ritual_daily_startup",
      "name": "Morning Startup Ritual",
      "category": "rituals",
      "icon": "🌅",
      "description": "Begin the day with clarity and intention",
      "unlockAtLevel": 1,
      "defaultDifficulty": "Easy",
      "defaultPriority": "Critical",
      "defaultEnergy": "Low Energy",
      "estimatedTime": 10,
      "repeatability": "Daily",
      "xpRange": { "min": 10, "max": 15 },
      
      "dynamicSteps": {
        "base": [
          "Open mission board and review commitments",
          "Check calendar for ${eventCount} key events",
          "Select ${priorityCount} top priorities",
          "Choose one must-win mission",
          "Define first micro-step",
          "Set timer for focus block",
          "Begin immediately"
        ],
        "variables": {
          "eventCount": { "type": "range", "min": 1, "max": 5, "default": 3 },
          "priorityCount": { "type": "range", "min": 2, "max": 5, "default": 3 }
        }
      },
      
      "successCriteria": "Top priorities selected and first action defined",
      "failureCondition": "Starting day reactively without plan",
      "reward": "+${xpGain} XP, startup streak",
      "recoveryMission": "Pick one must-win task only",
      "tags": ["ritual", "startup", "daily"]
    },

    {
      "id": "documentation_weekly_review",
      "name": "Weekly Review Mission",
      "category": "documentation",
      "icon": "📊",
      "description": "Review week's progress and plan next week",
      "unlockAtLevel": 2,
      "defaultDifficulty": "Medium",
      "defaultPriority": "Important",
      "defaultEnergy": "Standard Focus",
      "estimatedTime": 45,
      "repeatability": "Weekly",
      "xpRange": { "min": 35, "max": 55 },
      
      "dynamicSteps": {
        "base": [
          "Review daily logs from past week",
          "Identify ${winCount} wins and achievements",
          "Note ${blockerCount} blockers or challenges",
          "Extract ${insightCount} key insights",
          "Triage backlog: keep/drop/delay",
          "Set ${nextWeekCount} priorities for next week",
          "Prepare Monday's first mission"
        ],
        "variables": {
          "winCount": { "type": "range", "min": 3, "max": 7, "default": 5 },
          "blockerCount": { "type": "range", "min": 1, "max": 5, "default": 3 },
          "insightCount": { "type": "range", "min": 2, "max": 5, "default": 3 },
          "nextWeekCount": { "type": "range", "min": 2, "max": 5, "default": 3 }
        }
      },
      
      "successCriteria": "Week reviewed and ${nextWeekCount} priorities set",
      "failureCondition": "Week ends with no reflection or planning",
      "reward": "+${xpGain} XP, documentation streak",
      "recoveryMission": "Write 5-bullet weekly summary",
      "tags": ["review", "planning", "weekly"]
    }
  ],

  "generationRules": {
    "defaultChainLengths": {
      "today": 2,
      "week": 3,
      "month": 4
    },
    "templateSelection": {
      "priority": ["matching_tags", "user_level", "recent_usage"],
      "fallbackTemplate": "research_literature_review"
    }
  }
}
