      "domain": "Recovery",
      "theme": "Recovery & Reset Protocols",
      "defaultDifficulty": "Easy",
      "missionType": "Recovery Mission",
      "estimatedTime": 10,
      "microSteps": [
        "Pick one stalled mission.",
